# Django 基础配置。生产环境必须使用不可预测的密钥并关闭 DEBUG。
DJANGO_DEBUG=true
DJANGO_SECRET_KEY=replace-with-a-random-secret
DJANGO_ALLOWED_HOSTS=127.0.0.1,localhost
DJANGO_CSRF_TRUSTED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
DJANGO_LANGUAGE_CODE=zh-hans
DJANGO_TIME_ZONE=Asia/Shanghai

# MySQL 连接
MYSQL_DATABASE=pipecloud
MYSQL_USER=root
MYSQL_PASSWORD=
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306

# 主页数据看板服务端缓存秒数；设为 0 可关闭缓存。
PIPECLOUD_DASHBOARD_CACHE_TIMEOUT=180

# 业务数据与备份目录；留空时使用 backend/file 下的默认目录。
# PIPECLOUD_DATA_ROOT=C:/pipecloud/data
# PIPECLOUD_BACKUP_ROOT=C:/pipecloud/backups

# 定时维护任务。每组均支持 _HOUR、_MINUTE、_ENABLED。
# runserver 默认同时启动调度器；设为 false 后可改用独立的 run_scheduler 进程。
PIPECLOUD_SCHEDULER_AUTOSTART_WITH_RUNSERVER=true
PIPECLOUD_ANTI_CORROSION_COMPLETION_SYNC_HOUR=21
PIPECLOUD_ANTI_CORROSION_COMPLETION_SYNC_MINUTE=0
PIPECLOUD_ANTI_CORROSION_COMPLETION_SYNC_ENABLED=true
PIPECLOUD_CUTTING_COMPLETION_SYNC_HOUR=21
PIPECLOUD_CUTTING_COMPLETION_SYNC_MINUTE=5
PIPECLOUD_CUTTING_COMPLETION_SYNC_ENABLED=true
PIPECLOUD_WELDING_COMPLETION_SYNC_HOUR=21
PIPECLOUD_WELDING_COMPLETION_SYNC_MINUTE=10
PIPECLOUD_WELDING_COMPLETION_SYNC_ENABLED=true
PIPECLOUD_CUTTING_PLAN_ROLLOVER_HOUR=21
PIPECLOUD_CUTTING_PLAN_ROLLOVER_MINUTE=20
PIPECLOUD_CUTTING_PLAN_ROLLOVER_ENABLED=true
PIPECLOUD_WELDING_PLAN_ROLLOVER_HOUR=21
PIPECLOUD_WELDING_PLAN_ROLLOVER_MINUTE=30
PIPECLOUD_WELDING_PLAN_ROLLOVER_ENABLED=true
PIPECLOUD_PLAN_COMPLETION_SYNC_MISFIRE_GRACE_SECONDS=3600

# 文件解析并发参数
PIPECLOUD_PARSER_JOB_WORKERS=2
PIPECLOUD_IDF_PARSER_CHUNK_SIZE=50
PIPECLOUD_IDF_PARSER_SUBTASK_WORKERS=4
